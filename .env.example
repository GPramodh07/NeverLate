# Coral Server Configuration Example
# Copy this to your .env file and fill in the appropriate values

# Port for the NeverLate server
PORT=3000

# Coral Configuration
# URL where the Coral server is running
CORAL_BASE_URL=http://localhost:8080

# React Frontend configuration
VITE_API_URL=http://localhost:3000

# Demo Mode Configuration
# We use two separate variables to control Demo Mode safely:
# 1. MOCK_MODE tells the Node.js backend to bypass the Coral CLI and return mock data.
#    (Set this to "true" on any backend environment without the Coral CLI installed)
# 2. VITE_MOCK_MODE exposes the flag to the React frontend to display the "Demo Mode" UI badge.
MOCK_MODE=true
VITE_MOCK_MODE=true

# Debugging
CORAL_DEBUG=false
