{
  "name": "neverlate",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "NeverLate is an AI assistant that connects scattered personal information sources (email, calendar, notes, documents, tasks, etc.), understands them through a unified data layer using Coral, and proactively surfaces important things users are likely to miss before they become problems.",
  "homepage": "https://github.com/GPramodh07/Coral-Beans-2026#readme",
  "bugs": {
    "url": "https://github.com/GPramodh07/Coral-Beans-2026/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GPramodh07/Coral-Beans-2026.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev:web": "npm run dev -w @neverlate/web",
    "dev:server": "npm run dev -w @neverlate/server",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "start": "tsx watch src/index.ts",
    "build": "npm run build --workspaces",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "concurrently": "^9.2.1",
    "prettier": "3.8.3",
    "tsx": "^4.22.3"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "googleapis": "^172.0.0"
  }
}
